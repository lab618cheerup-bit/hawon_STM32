/* USER CODE BEGIN 4 */

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
   if (GPIO_Pin == GPIO_PIN_9) {
       if (!EStop_IsPressed()) return;
       estop_flag = 1;
       htim5.Instance->CCR1 = 0;
       htim5.Instance->CCR2 = 0;
       return;
   }
    if (GPIO_Pin == GPIO_PIN_15) // Left A (PB15)
    {
        if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_15) == HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_14))
            left_encoder_value--;
        else
            left_encoder_value++;
    }
    else if (GPIO_Pin == GPIO_PIN_14) // Left B (PB14)
    {
        if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_15) == HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_14))
            left_encoder_value++;
        else
            left_encoder_value--;
    }
    else if (GPIO_Pin == GPIO_PIN_12) // Right A (PA12)
    {
        if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_12) == HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_11))
            right_encoder_value++;
        else
            right_encoder_value--;
    }
    else if (GPIO_Pin == GPIO_PIN_11) // Right B (PA11)
    {
        if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_12) == HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_11))
            right_encoder_value--;
        else
            right_encoder_value++;
    }
}
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart == &huart4) {
        uart_irq_cnt++;

        if (rx_data != '\n' && rx_data != '\r') {
            if (rx_index < sizeof(rx_buffer) - 1) {
                rx_buffer[rx_index++] = rx_data;
            }
        }
        else {
            if (rx_index > 0) {
                BaseType_t xHigherPriorityTaskWoken = pdFALSE;
                UartMessage_t txMsg;

                rx_buffer[rx_index] = '\0';
                memset(&txMsg, 0, sizeof(txMsg));
                strncpy(txMsg.msg, (char*)rx_buffer, sizeof(txMsg.msg) - 1);

                if (xQueueSendFromISR(uartQueue, &txMsg, &xHigherPriorityTaskWoken) == pdPASS)
                    uart_queue_ok_cnt++;
                else
                    uart_queue_fail_cnt++;

                rx_index = 0;
                memset(rx_buffer, 0, sizeof(rx_buffer));

                portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
            }
        }

        HAL_UART_Receive_IT(&huart4, (uint8_t*)&rx_data, 1);
    }
}
/* USER CODE END 4 */

