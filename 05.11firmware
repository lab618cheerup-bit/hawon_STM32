#ifdef __GNUC__
int __io_putchar(int ch)
#else
int fputc(int ch, FILE *f)
#endif
{
  if (ch == '\n') {
    uint8_t cr = '\r';
    HAL_UART_Transmit(&huart4, &cr, 1, 0xFFFF);
  }
  uint8_t c = (uint8_t)ch;
  HAL_UART_Transmit(&huart4, &c, 1, 0xFFFF);
  return ch;
}
static void Motor_Set(float spd_L, float spd_R)
{
    // 왼쪽: 양수 = 전진 되도록 반전
    if (spd_L >= 0) {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, 1);
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_4,  0);
    } else {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, 0);
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_4,  1);
    }

    // 오른쪽: 양수 = 전진 되도록 반전
    if (spd_R >= 0) {
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_5, 0);
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_6, 1);
    } else {
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_5, 1);
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_6, 0);
    }

    int pwm_L = (int)fabsf(spd_L);
    int pwm_R = (int)fabsf(spd_R);

    if (pwm_L > 200) pwm_L = 200;
    if (pwm_R > 200) pwm_R = 200;

    htim5.Instance->CCR1 = pwm_L;  // 왼쪽
    htim5.Instance->CCR2 = pwm_R;  // 오른쪽
}
static void Motor_EStop(void) {
    cmd_vel_x = 0.0f; cmd_vel_z = 0.0f;
    dist_driving = 0; turn_mode = 0; stop_flag = 1;
    prev_err_v = 0.0f; old_err_v = 0.0f;
    prev_err_w = 0.0f; old_err_w = 0.0f;
    speed = 0.0f; speed_r = 0.0f;
    htim5.Instance->CCR1 = 0;
    htim5.Instance->CCR2 = 0;
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_4,  GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_5,  GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_6,  GPIO_PIN_RESET);
}
static uint8_t EStop_IsPressed(void)
{
    if (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_9) == GPIO_PIN_SET) return 1;
    return 0;
}
uint16_t get_filtered_distance(volatile uint16_t* buffer, int* index, uint16_t new_val)
{
    buffer[*index] = new_val;
    *index = (*index + 1) % FILTER_BUFFER_SIZE;

    long sum = 0;
    int valid = 0;
    for (int i = 0; i < FILTER_BUFFER_SIZE; i++) {
        if (buffer[i] > 0 && buffer[i] < 1700) {
            sum += buffer[i];
            valid++;
        }
    }
    return (valid > 0) ? (sum / valid) : 0;
}
void apply_sensor_config(void)
{
    setSignalRateLimit(200);
    setVcselPulsePeriod(VcselPeriodPreRange, 14);
    setVcselPulsePeriod(VcselPeriodFinalRange, 10);
    setMeasurementTimingBudget(330000UL);  // 330ms
}
float kalman_update(Kalman* kf, float measurement) {
    kf->P = kf->P + kf->Q;
    float K = kf->P / (kf->P + kf->R);
    kf->x = kf->x + K * (measurement - kf->x);
    kf->P = (1 - K) * kf->P;
    return kf->x;
}
static inline uint16_t compensate_L(uint16_t raw) {
    int v = (int)(0.921f * raw - 1.8f);
    if (v < 0) v = 0;
    return (uint16_t)v;
}

static inline uint16_t compensate_R(uint16_t raw) {
    int v = (int)(0.885f * raw - 8.0f);
    if (v < 0) v = 0;
    return (uint16_t)v;
}

void Task_PID(void *argument)
{
   vTaskDelay(pdMS_TO_TICKS(200));
    uint32_t last_tick = HAL_GetTick();


       for(;;)
       {
          if (EStop_IsPressed()) {
                  estop_flag = 1;
                  Motor_EStop();
                  vTaskDelay(pdMS_TO_TICKS(5));
                  continue;
              }

              // 2. 방금 해제됐으면 초기화
              if (estop_flag) {
                  estop_flag = 0;
                  cmd_vel_x = 0.0f; cmd_vel_z = 0.0f;
                  dist_driving = 0; turn_mode = 0; stop_flag = 1;
                  prev_err_v = old_err_v = 0.0f;
                  prev_err_w = old_err_w = 0.0f;
                  speed = speed_r = 0.0f;
                  prev_enc_L = left_encoder_value;
                  prev_enc_R = right_encoder_value;
                  Motor_EStop();
                  printf("ESTOP RELEASED\n");
                  vTaskDelay(pdMS_TO_TICKS(5));
                  continue;
              }
        if (HAL_GetTick() - last_tick >= DT_MS)
        {
           last_tick = HAL_GetTick();
           int32_t dL = left_encoder_value  - prev_enc_L;
           int32_t dR = right_encoder_value - prev_enc_R;
           prev_enc_L = left_encoder_value;
           prev_enc_R = right_encoder_value;

           float dist_L = dL * ANGLE_PER_COUNT * WHEEL_RADIUS * (-1.0f);
           float dist_R = dR * ANGLE_PER_COUNT * WHEEL_RADIUS * (-1.0f);

           float s_step     = 0.5f * (dist_L + dist_R);
           float theta_step = (dist_L - dist_R) / WHEEL_BASE;

           v_meas = s_step     / DT_S;
           w_meas = theta_step / DT_S;

           double mid_th = odom_th + theta_step * 0.5;
           odom_x  += s_step * cos(mid_th);
           odom_y  += s_step * sin(mid_th);
           odom_th += theta_step;
           // ⭐ 여기부터 추가 ⭐
           float target_vel_x = cmd_vel_x;

            if (dist_driving) {
             float remaining = dist_target - total_dist;

             if (remaining > 0.0f) {
                 float v = remaining * 0.6f;

                 if (v > 0.2f) v = 0.2f;
                 if (v < 0.03f) v = 0.03f;

                 target_vel_x = v;
             } else {
                 target_vel_x = 0.0f;
             }
         }

           if (stop_flag == 0) {
              err_v = target_vel_x - v_meas;
               pid_v  = Kp * (err_v - prev_err_v)
                      + Ki *  err_v
                      + Kd * (err_v - 2.0f * prev_err_v + old_err_v);
               old_err_v  = prev_err_v;
               prev_err_v = err_v;

               err_w  = cmd_vel_z - w_meas;
               pid_w  = Kp_a * (err_w - prev_err_w)
                      + Ki_a *  err_w
                      + Kd_a * (err_w - 2.0f * prev_err_w + old_err_w);
               old_err_w  = prev_err_w;
               prev_err_w = err_w;



               speed   += pid_v + pid_w;
               speed_r += pid_v - pid_w;
           } else {
               speed   -= speed   / 5.0f;
               speed_r -= speed_r / 5.0f;
           }

           if (speed   >  200) speed   =  200;
           if (speed   < -200) speed   = -200;
           if (speed_r >  200) speed_r =  200;
           if (speed_r < -200) speed_r = -200;

           Motor_Set(speed, speed_r);

           if (cmd_vel_x == 0.0f && cmd_vel_z == 0.0f)
               stop_flag = 1;
           else
               stop_flag = 0;

         total_dist += fabsf(s_step);

         if (dist_driving && total_dist >= dist_target) {
             cmd_vel_x = 0.0f;
             cmd_vel_z = 0.0f;
             dist_driving = 0;
             printf("DONE total:%.4f odom_x:%.4f odom_y:%.4f\n",
                    total_dist, (float)odom_x, (float)odom_y);
         }

        }
        if (turn_mode)
        {
            float err = target_angle - odom_th;

            if (fabsf(err) < 0.05f)   // 약 3도 오차
            {
                cmd_vel_z = 0.0f;
                turn_mode = 0;
                printf("TURN DONE angle:%.3f\n", odom_th);
            }
        }

        vTaskDelay(pdMS_TO_TICKS(5));
       }

}
void Task_Razor(void *argument)
{

   uint32_t last_tick = HAL_GetTick();


    for(;;)
    {
        if (HAL_GetTick() - last_tick >= 50)
        {
            last_tick = HAL_GetTick();

            VL53L0X_I2C_Handler = hi2c1;
            if (isMeasurementReady()) {
                uint16_t raw = readMeasurementResult(&distL_stats);
                if (distL_stats.rangeStatus == 0 || distL_stats.rangeStatus == 11) {
                    uint16_t filtered = compensate_L(
                        get_filtered_distance(distL_buffer, &buffer_index_L, raw)
                    );
                    if (kfL.x == 0) kfL.x = filtered;
                    distanceL = (uint16_t)kalman_update(&kfL, (float)filtered);
                }
                startSingleMeasurement_nonBlocking();
            }

            VL53L0X_I2C_Handler = hi2c2;
            if (isMeasurementReady()) {
                uint16_t raw = readMeasurementResult(&distR_stats);
                if (distR_stats.rangeStatus == 0 || distR_stats.rangeStatus == 11) {
                    uint16_t filtered = compensate_R(
                        get_filtered_distance(distR_buffer, &buffer_index_R, raw)
                    );
                    if (kfR.x == 0) kfR.x = filtered;
                    distanceR = (uint16_t)kalman_update(&kfR, (float)filtered);
                }
                startSingleMeasurement_nonBlocking();
            }


        }

        vTaskDelay(pdMS_TO_TICKS(5));
    }
}
void Task_UART(void *argument)
{
      UartMessage_t rxMsg;
       float v, w;
       uint32_t last_print = 0;

       printf("UART task alive\n");

       for(;;)
       {
           if (HAL_GetTick() - last_print >= 2000) {
               last_print = HAL_GetTick();
               printf("irq:%lu ok:%lu fail:%lu\n",
                      uart_irq_cnt, uart_queue_ok_cnt, uart_queue_fail_cnt);
           }

           if (xQueueReceive(uartQueue, &rxMsg, pdMS_TO_TICKS(100)) == pdPASS)
           {
              if (estop_flag) {
                      printf("ESTOP ACTIVE - CMD IGNORED\n");
                      continue;
                  }
               v = 0.0f;
               w = 0.0f;


                if (sscanf(rxMsg.msg, "v%f w%f", &v, &w) == 2)
               {
                   dist_driving = 0;
                   cmd_vel_x = -v;
                   cmd_vel_z = -w;
                   printf("OK v:%.3f w:%.3f\n", v, w);
               }
               else if (sscanf(rxMsg.msg, "d%f", &dist_target) == 1)
               {
                   odom_x = 0.0;
                   odom_y = 0.0;
                   odom_th = 0.0;
                   total_dist = 0.0f;

                   prev_err_v = old_err_v = 0.0f;
                   prev_err_w = old_err_w = 0.0f;
                   speed = speed_r = 0.0f;

                   cmd_vel_x = 0.2f;
                   cmd_vel_z = 0.0f;
                   dist_driving = 1;

                   printf("GO %.3f m\n", dist_target);
               }
               else if (strcmp(rxMsg.msg, "laser") == 0)
               {
                   printf("L:%d R:%d | statusL:%d statusR:%d | rawLbuf0:%d rawRbuf0:%d\n",
                          distanceL, distanceR,
                          distL_stats.rangeStatus, distR_stats.rangeStatus,
                          distL_buffer[0], distR_buffer[0]);
               }
               else if (strcmp(rxMsg.msg, "turnL") == 0)
               {
                   target_angle = odom_th + 1.57f;
                   turn_mode = 1;
                   dist_driving = 0;

                   prev_err_w = 0.0f;
                   old_err_w  = 0.0f;
                   speed = 0.0f;
                   speed_r = 0.0f;

                   cmd_vel_x = 0.0f;
                   cmd_vel_z = 0.5f;
                   printf("TURN LEFT 90\n");
               }
               else if (strcmp(rxMsg.msg, "turnR") == 0)
               {
                   target_angle = odom_th - 1.57f;
                   turn_mode = 1;
                   dist_driving = 0;

                   prev_err_w = 0.0f;
                   old_err_w  = 0.0f;
                   speed = 0.0f;
                   speed_r = 0.0f;

                   cmd_vel_x = 0.0f;
                   cmd_vel_z = -0.5f;
                   printf("TURN RIGHT 90\n");
               }
               else if (strcmp(rxMsg.msg, "estop_read") == 0)
               {
                   printf("PC9:%d estop:%d flag:%d\n",
                       HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_9),
                       EStop_IsPressed(),
                       estop_flag);
               }
               else
               {
                   printf("PARSE FAIL\n");
               }
           }
       }
}
void Task_ODOM(void *argument)
{
    uint32_t last_odom_tx = HAL_GetTick();

    for (;;)
    {
        if (HAL_GetTick() - last_odom_tx >= 50)  // 20Hz
        {
            last_odom_tx = HAL_GetTick();

            float snap_x, snap_y, snap_th, snap_v, snap_w;

            taskENTER_CRITICAL();
            snap_x  = (float)odom_x;
            snap_y  = (float)odom_y;
            snap_th = (float)odom_th;
            snap_v  = v_meas;
            snap_w  = w_meas;
            taskEXIT_CRITICAL();
            float out_x  = -snap_x;
            float out_y  = -snap_y;
            float out_th = -snap_th;
            float out_v  = -snap_v;
            float out_w  = -snap_w;

            printf("ODOM %.4f %.4f %.4f %.4f %.4f\n",
                   out_x,
                   out_y,
                   out_th,
                   out_v,
                   out_w);
        }
        vTaskDelay(pdMS_TO_TICKS(5));
    }
}
/* task's priority */
#define TASK_MAIN_PRIO       19
#define TASK_PID_PRIO       18
#define TASK_Razor_PRIO       17
#define TASK_UART_PRIO       16
#define TASK_ODOM_PRIO 15

