#define FILTER_BUFFER_SIZE 20
#define DT_MS           39
#define DT_S            0.039f
#define WHEEL_RADIUS    0.0625f
#define WHEEL_BASE      0.481f
#define ENCODER_PPR_4X  3172
#define ANGLE_PER_COUNT (2.0f * 3.141592f / ENCODER_PPR_4X)  // rad/count
typedef struct {
    float x;
    float P;
    float Q;
    float R;
} Kalman;

