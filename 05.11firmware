/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_TIM5_Init();
  MX_UART4_Init();
  MX_I2C1_Init();
  MX_I2C2_Init();
  /* USER CODE BEGIN 2 */
  HAL_TIM_PWM_Start(&htim5, TIM_CHANNEL_1);
  HAL_TIM_PWM_Start(&htim5, TIM_CHANNEL_2);
  Motor_EStop();

  VL53L0X_I2C_Handler = hi2c1;
  if (!initVL53L0X(1, &hi2c1)) {
      //printf("L sensor init FAIL\n");
  } else {
      //printf("L sensor init OK\n");
      apply_sensor_config();
  }


  // I2C2 센서 초기화
  VL53L0X_I2C_Handler = hi2c2;
  if (!initVL53L0X(1, &hi2c2)) {
     // printf("R sensor init FAIL\n");
  } else {
      //printf("R sensor init OK\n");
      apply_sensor_config();
  }



  // 첫 측정 시작
  VL53L0X_I2C_Handler = hi2c1;
  startSingleMeasurement_nonBlocking();
  VL53L0X_I2C_Handler = hi2c2;
  startSingleMeasurement_nonBlocking();

  ctrl_tick = HAL_GetTick();


  /* USER CODE END 2 */

  /* USER CODE BEGIN RTOS_MUTEX */
  /* add mutexes, ... */
  /* USER CODE END RTOS_MUTEX */

  /* USER CODE BEGIN RTOS_SEMAPHORES */
  /* add semaphores, ... */
  /* USER CODE END RTOS_SEMAPHORES */

  /* USER CODE BEGIN RTOS_TIMERS */
  /* start timers, add new ones, ... */
  /* USER CODE END RTOS_TIMERS */

  /* USER CODE BEGIN RTOS_QUEUES */
  uartQueue = xQueueCreate(4, sizeof(UartMessage_t));
  if (uartQueue == NULL) {
      Error_Handler();
  }
  /* USER CODE END RTOS_QUEUES */

  /* Create the thread(s) */
  /* definition and creation of defaultTask */
  osThreadDef(defaultTask, StartDefaultTask, osPriorityNormal, 0, 128);
  defaultTaskHandle = osThreadCreate(osThread(defaultTask), NULL);

  /* USER CODE BEGIN RTOS_THREADS */
  xTaskCreate(Task_PID, "Task_PID", 256, NULL, TASK_PID_PRIO, &xHandlePID);
  xTaskCreate(Task_Razor, "Task_Razor", 256, NULL, TASK_Razor_PRIO, &xHandleRazor);
  xTaskCreate(Task_UART, "Task_UART", 512, NULL, TASK_UART_PRIO, &xHandleUART);
  xTaskCreate(Task_ODOM, "Task_ODOM", 512, NULL, TASK_ODOM_PRIO, &xHandleODOM);
  HAL_UART_Receive_IT(&huart4, (uint8_t*)&rx_data, 1);

  /* USER CODE END RTOS_THREADS */

  /* Start scheduler */
  osKernelStart();

  /* We should never get here as control is now taken by the scheduler */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */

  while (1)
  {


    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

/**
  * @brief System Clock Configuration
  * @retval None
  */
void SystemClock_Config(void)
{
  RCC_OscInitTypeDef RCC_OscInitStruct = {0};
  RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

