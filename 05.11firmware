// 엔코더
volatile int32_t left_encoder_value  = 0;
volatile int32_t right_encoder_value = 0;
static int32_t prev_enc_L = 0;
static int32_t prev_enc_R = 0;

// 오도메트리
static double odom_x  = 0.0;
static double odom_y  = 0.0;
static double odom_th = 0.0;

// 속도 측정값
static float v_meas = 0.0f;  // m/s
static float w_meas = 0.0f;  // rad/s

// cmd_vel (ROS or 시리얼 명령)
static float cmd_vel_x = 0.0f;  // 목표 선속도 m/s
static float cmd_vel_z = 0.0f;  // 목표 각속도 rad/s

// PID - 선속도
static float Kp   = 4.0f;
static float Ki   = 8.0f;
static float Kd   = 1.6f;
static float err_v      = 0.0f;
static float prev_err_v = 0.0f;
static float old_err_v  = 0.0f;
static float pid_v      = 0.0f;

// PID - 각속도
static float Kp_a   = 5.0f;
static float Ki_a   = 6.25f;
static float Kd_a   = 1.3f;
static float err_w      = 0.0f;
static float prev_err_w = 0.0f;
static float old_err_w  = 0.0f;
static float pid_w      = 0.0f;

// 모터 출력
static float speed   = 0.0f;  // 왼쪽
static float speed_r = 0.0f;  // 오른쪽

// 정지 플래그
static int stop_flag = 1;
volatile uint8_t estop_flag = 0;

// UART 수신
static char rx_buffer[64] = {0};
static int  rx_index = 0;

// 제어 주기 타이머
static uint32_t ctrl_tick = 0;


uint8_t dataReady = 0;

uint16_t laser_distance_mm = 0;   // 최종 거리값
uint8_t laser_valid = 0;          // 1: 정상거리, 0: 비정상
uint8_t laser_init_ok = 0;        // 1: 센서 초기화 성공
statInfo_t_VL53L0X distL_stats = {0};
statInfo_t_VL53L0X distR_stats = {0};
uint16_t distanceL = 0;
uint16_t distanceR = 0;
uint32_t print_t = 0;
volatile uint16_t distL_buffer[FILTER_BUFFER_SIZE] = {0};
volatile uint16_t distR_buffer[FILTER_BUFFER_SIZE] = {0};
int buffer_index_L = 0;
int buffer_index_R = 0;
Kalman kfL = {0, 1, 0.5f, 15.0f};
Kalman kfR = {0, 1, 0.5f, 15.0f};
static float total_dist = 0.0f;
static float dist_target = 0.0f;
static int   dist_driving = 0;
static volatile uint8_t rx_data = 0;
volatile uint32_t uart_irq_cnt = 0;
volatile uint32_t uart_queue_ok_cnt = 0;
volatile uint32_t uart_queue_fail_cnt = 0;
static float target_angle = 0.0f;
static int   turn_mode = 0;
static volatile uint32_t estop_last_tick = 0;
